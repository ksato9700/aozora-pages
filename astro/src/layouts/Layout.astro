---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Aozora Pages',
  description = 'A modern viewer for Aozora Bunko digital library',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Noto+Serif+JP:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --background: #0f172a;
    --foreground: #f8fafc;
    --primary: #38bdf8;
    --secondary: #818cf8;
    --accent: #2dd4bf;
    --muted: #94a3b8;
    --card-bg: rgba(30, 41, 59, 0.7);
    --card-border: rgba(148, 163, 184, 0.2);
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-serif: 'Noto Serif JP', serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    color: var(--foreground);
    background: radial-gradient(circle at top left, #1e293b, #0f172a);
    font-family: var(--font-sans);
    min-height: 100vh;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  th {
    text-align: left;
  }

  td {
    padding-left: 3rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .text-gradient {
    background: linear-gradient(to right, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .glass-panel {
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--card-border);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .flex { display: flex; }
  .items-center { align-items: center; }
  .items-end { align-items: flex-end; }
  .justify-between { justify-content: space-between; }
  .gap-4 { gap: 1rem; }
  .mb-2 { margin-bottom: 0.5rem; }
  .mb-4 { margin-bottom: 1rem; }
  .mb-6 { margin-bottom: 1.5rem; }
  .mb-8 { margin-bottom: 2rem; }
  .mb-16 { margin-bottom: 4rem; }
  .mt-2 { margin-top: 0.5rem; }
  .mt-8 { margin-top: 2rem; }
  .space-y-12 > * + * { margin-top: 3rem; }
  .text-sm { font-size: 0.875rem; }
  .text-xs { font-size: 0.75rem; }
  .text-muted { color: var(--muted); }
  .text-primary { color: var(--primary); }
  .text-accent { color: var(--accent); }
  .text-center { text-align: center; }
  .font-bold { font-weight: 700; }
  .uppercase { text-transform: uppercase; }
  .tracking-wider { letter-spacing: 0.05em; }
  .w-full { width: 100%; }
  .w-32 { width: 8rem; }
  .p-8 { padding: 2rem; }
  .rounded-xl { border-radius: 0.75rem; }
  .hover\:underline:hover { text-decoration: underline; }
  .border-b { border-bottom: 1px solid; }
  .border-gray-200 { border-color: rgba(209, 213, 219, 0.3); }
  .text-left { text-align: left; }
  .text-red-800 { color: #991b1b; }
  .text-gray-400 { color: #9ca3af; }
  .text-gray-500 { color: #6b7280; }
</style>
