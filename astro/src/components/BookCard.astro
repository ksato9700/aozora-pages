---
import type { Book } from '../types/aozora';

interface Props {
  book: Book;
  authorName?: string;
}

const { book, authorName } = Astro.props;
---

<div class="card">
  <div class="glass-panel">
    <div class="gradient-overlay"></div>
    <div class="content">
      <a href={`/books/${book.book_id}`} class="link-area">
        <h3 class="title">{book.title}</h3>
        {book.subtitle && <p class="subtitle">{book.subtitle}</p>}
        <div class="meta">
          {authorName && <div class="author">{authorName}</div>}
          <div class="date">{book.release_date}</div>
        </div>
      </a>
      <div class="footer">
        <a href={`/read/${book.book_id}?format=html`} class="badge">今すぐ読む</a>
      </div>
    </div>
  </div>
</div>

<style>
  .card {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .glass-panel {
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--card-border);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    border-radius: 0.75rem;
    padding: 1.5rem;
    height: 100%;
    transition: all 0.3s ease;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .card:hover .glass-panel {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    border-color: rgba(56, 189, 248, 0.3);
  }

  .gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.1), transparent);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .card:hover .gradient-overlay {
    opacity: 1;
  }

  .content {
    position: relative;
    z-index: 10;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .link-area {
    flex: 1;
    text-decoration: none;
    color: inherit;
  }

  .title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    font-family: var(--font-serif);
    letter-spacing: 0.025em;
    transition: color 0.3s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card:hover .title {
    color: var(--primary);
  }

  .subtitle {
    font-size: 0.875rem;
    color: var(--muted);
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: #d1d5db;
  }

  .author {
    font-weight: 500;
  }

  .date {
    font-size: 0.75rem;
    color: #9ca3af;
    margin-top: 0.25rem;
  }

  .footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .badge {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--primary);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .card:hover .badge {
    background: var(--primary);
    color: white;
  }
</style>
