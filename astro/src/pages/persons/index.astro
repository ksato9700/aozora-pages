---
import Layout from '../../layouts/Layout.astro';
import PersonCard from '../../components/PersonCard.astro';
import SearchSection from '../../components/SearchSection';
import { getData } from '../../lib/data';

const { persons } = await getData();
// Show the 20 highest person_id values (most recently added)
const recentPersons = [...persons.values()]
  .sort((a, b) => b.person_id.localeCompare(a.person_id))
  .slice(0, 20);
---

<Layout title="著者一覧 — Aozora Pages">
  <main class="main">
    <div class="container">
      <header class="header">
        <a href="/" class="back-link">&larr; ホームへ</a>
        <h1 class="title"><span class="text-gradient">著者を探す</span></h1>
      </header>

      <SearchSection client:load />

      <section style="margin-top: 2rem;">
        <h2 class="section-title">著者一覧</h2>
        <div class="grid">
          {recentPersons.map((person) => (
            <PersonCard person={person} />
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .main {
    min-height: 100vh;
    padding: 3rem 0;
  }

  .header {
    margin-bottom: 2rem;
  }

  .back-link {
    color: var(--muted);
    font-size: 0.875rem;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--foreground);
  }

  .title {
    font-size: 2.5rem;
    font-weight: 800;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 2rem;
    border-left: 4px solid var(--accent);
    padding-left: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
