# Google Application Credentials for Firestore (build-time only)
# Option A: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option B: inline JSON content (useful in CI)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Algolia (also exposed to the browser as PUBLIC_*)
PUBLIC_ALGOLIA_APP_ID=your_app_id
PUBLIC_ALGOLIA_SEARCH_KEY=your_search_only_key

# Cloudflare Pages deploy hook (triggered by py-aozora-data after import)
# CF_PAGES_DEPLOY_HOOK_URL=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/...
